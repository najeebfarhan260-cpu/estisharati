.glass-card { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }

.service-btn { transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); }

.service-btn:hover { transform: translateY(-4px); }

.service-btn.active { background: linear-gradient(135deg, rgb(26, 35, 126) 0%, rgb(46, 125, 50) 100%); color: white; box-shadow: rgba(26, 35, 126, 0.4) 0px 10px 25px -5px; }

.glow-hover:hover { box-shadow: rgba(46, 125, 50, 0.5) 0px 0px 20px, rgba(0, 0, 0, 0.1) 0px 8px 16px; }

.step-indicator { transition: 0.4s; }

.step-indicator.active { background: linear-gradient(135deg, rgb(253, 216, 53) 0%, rgb(250, 204, 21) 100%); color: rgb(26, 35, 126); transform: scale(1.1); }

.step-indicator.completed { background: rgb(46, 125, 50); color: white; }

input:focus, select:focus, textarea:focus { outline: none; border-color: rgb(46, 125, 50); box-shadow: rgba(46, 125, 50, 0.1) 0px 0px 0px 3px; }

.autocomplete-list { max-height: 200px; overflow-y: auto; }

.autocomplete-item:hover { background: rgb(241, 245, 249); }

@keyframes countUp { 
  0% { opacity: 0; transform: scale(0.5); }
  100% { opacity: 1; transform: scale(1); }
}

.stat-number { animation: 0.5s ease-out 0s 1 normal none running countUp; }

.wave-divider { display: block; width: 100%; height: 60px; }

.observer-hidden { opacity: 0; transform: translateY(30px); }

.observer-show { opacity: 1; transform: translateY(0px); transition: 0.6s ease-out; }

::-webkit-scrollbar { width: 8px; }

::-webkit-scrollbar-track { background: rgb(241, 241, 241); }

::-webkit-scrollbar-thumb { background: linear-gradient(rgb(26, 35, 126), rgb(46, 125, 50)); border-radius: 4px; }
